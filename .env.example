# Copiar a .env y completar

# Puerto del backend (el frontend en dev proxea /api hacia este puerto)
PORT=5000

# IP de esta máquina en la red interna. n8n (nodo HTTP Request) apunta a
# http://HOST_IP:PORT/api/webhooks/ticket para postear cada llamada.
# Actualizar este valor cuando cambie la IP o se mude a otro servidor.
HOST_IP=192.168.1.100

# API key que n8n debe mandar en el header "x-api-key" al POSTear a /api/webhooks/ticket
WEBHOOK_API_KEY=generar-una-clave-larga-y-aleatoria

# Ruta del archivo SQLite (opcional, por defecto <repo>/data/tickets.db)
# TICKETS_DB_PATH=C:\otra\ruta\tickets.db
